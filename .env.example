# ──────────────────────────────────────────────
# Valorant Update Bot — Configuration
# ──────────────────────────────────────────────

# 1. Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_bot_token_here

# 2. Channel ID(s) where updates will be posted (comma-separated for multiple)
DISCORD_CHANNEL_IDS=123456789012345678

# 3. How often to check for updates (in minutes). Default: 10
CHECK_INTERVAL_MINUTES=10

# 4. (Optional) Custom embed color in hex. Default: #FD4556 (Valorant red)
EMBED_COLOR=#FD4556
